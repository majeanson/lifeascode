{
  "name": "@life-as-code/api",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsdown --watch ./src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@life-as-code/auth": "workspace:*",
    "@life-as-code/db": "workspace:*",
    "@life-as-code/validators": "workspace:*",
    "@trpc/server": "catalog:trpc",
    "superjson": "catalog:trpc",
    "zod": "catalog:prod"
  },
  "devDependencies": {
    "@life-as-code/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
