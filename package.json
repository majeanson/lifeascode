{
  "name": "lifeascode",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "turbo run db:generate -F @life-as-code/db",
    "db:migrate": "turbo run db:migrate -F @life-as-code/db",
    "db:push": "turbo run db:push -F @life-as-code/db",
    "db:studio": "turbo run db:studio -F @life-as-code/db",
    "dev": "turbo dev --continue",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ws": "bunx sherif@latest",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "turbo": "^2.7.5"
  },
  "packageManager": "bun@1.3.0",
  "catalogs": {
    "prod": {
      "@tanstack/react-query": "^5.90.19",
      "zod": "^4.3.5"
    },
    "dev": {
      "@types/node": "^25.0.9",
      "dotenv-cli": "^11.0.0",
      "tsdown": "^0.19.0",
      "typescript": "^5.9.3"
    },
    "react": {
      "@types/react": "^19.2.8",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.3",
      "react-dom": "^19.2.3"
    },
    "tailwind": {
      "@tailwindcss/postcss": "^4.1.18",
      "@tailwindcss/vite": "^4.1.18",
      "tailwindcss": "^4.1.18",
      "uniwind": "^1.2.4"
    },
    "trpc": {
      "@trpc/server": "^11.8.1",
      "@trpc/client": "^11.8.1",
      "@trpc/tanstack-react-query": "^11.8.1",
      "superjson": "^2.2.6"
    },
    "orpc": {
      "@orpc/server": "^1.13.4",
      "@orpc/client": "^1.13.4",
      "@orpc/tanstack-query": "^1.13.4"
    }
  }
}
